# Supabase — get both values from: Supabase Dashboard → Settings → API Keys
# SUPABASE_URL: Settings → General → Project ID (construct as shown below)
# SUPABASE_KEY: Settings → API Keys → Secret keys → default (the service_role key)
#   ⚠ Use the SECRET key (service_role), NOT the publishable/anon key.
#   The backend runs server-side only — the secret key is never exposed to browsers.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Leave as-is for local dev — enables mock Swipey responses
SWIPEY_API_KEY=stub-local-dev
SWIPEY_API_URL=https://api.swipey.app

# Swipey Bill Payment API — set both to go live (mock mode when BP key is blank/stub)
SWIPEY_BP_API_KEY=
SWIPEY_COMPANY_UUID=

SECRET_KEY=generate-a-random-64-char-hex-string-here
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=production   # set to "development" only for local dev; disables /auth/setup-admin in prod
